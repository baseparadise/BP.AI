# ====== Untuk bot always-on di Railway (bot.js) ======
# Bot Token dari Discord Developer Portal > Applications > (botmu) > Bot > Reset Token
DISCORD_TOKEN=

# API key Gemini (Google AI Studio). Wajib untuk fitur AI.
GEMINI_API_KEY=

# ====== Opsional (punya default di kode) ======
# Model teks utama
GEMINI_MODEL=gemini-2.5-flash
# Model cadangan kalau utama overload
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
# Model generate gambar
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ====== Hanya dipakai webhook /cp di Vercel (api/index.js), TIDAK perlu di Railway ======
# APP_ID=
# PUBLIC_KEY=
